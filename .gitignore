.claude/*
!.claude/skills/
!.claude/skills/**
node_modules/
Images/
Sounds/
*.json
!package.json
!package-lock.json
!vercel.json
!capacitor.config.json
!taxonomy/*.json
# Bundled board-language dictionaries are source, not build output.
!api/_lib/i18n/*.json
# Xcode asset catalogs store image metadata in files named Contents.json — the
# blanket *.json above was silently dropping them, so new imagesets shipped
# without their metadata and rendered blank. Always keep these.
!**/*.xcassets/**/Contents.json
!**/*.appiconset/Contents.json
!**/*.imageset/Contents.json

# Capacitor native build artifacts (the ios/ project itself is generated on the Mac)
ios/App/Pods/
ios/App/App/public/
ios/App/build/
package-lock.json
