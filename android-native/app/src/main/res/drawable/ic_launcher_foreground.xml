<?xml version="1.0" encoding="utf-8"?>
<!-- Simple white globe mark on the brand-pink adaptive background. Replace via
     Android Studio's Image Asset tool with the real app icon
     (fletcher_app_icon_transparent_1024.png at the repo root) before shipping. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp" android:height="108dp"
    android:viewportWidth="108" android:viewportHeight="108">
    <group android:scaleX="0.6" android:scaleY="0.6" android:pivotX="54" android:pivotY="54">
        <!-- Globe circle -->
        <path android:fillColor="#FFFFFF"
            android:pathData="M54,18 a36,36 0 1,0 0.001,0 Z M54,24 a30,30 0 1,1 -0.001,0 Z" />
        <!-- Equator -->
        <path android:fillColor="#FFFFFF"
            android:pathData="M24,51 h60 v6 h-60 Z" />
        <!-- Meridian (ellipse outline drawn as two arcs) -->
        <path android:strokeColor="#FFFFFF" android:strokeWidth="6" android:fillColor="#00000000"
            android:pathData="M54,21 a16,33 0 1,0 0.001,0" />
    </group>
</vector>
