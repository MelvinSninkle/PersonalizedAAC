{
  "rewrites": [
    { "source": "/u/:slug", "destination": "/app.html" },
    { "source": "/parent/:slug", "destination": "/parent.html" },
    { "source": "/therapist/:slug", "destination": "/therapist.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/reset", "destination": "/reset.html" },
    { "source": "/onboard/:slug", "destination": "/onboard.html" },
    { "source": "/onboard", "destination": "/onboard.html" }
  ]
}
